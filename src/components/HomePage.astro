---
import { getCollection } from 'astro:content';
import AudioField from './AudioField.astro';
import ProjectCard from './ProjectCard.astro';
import PublicationList from './PublicationList.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { copy, localePath, type Locale } from '../data/site';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = copy[locale];
const projects = (await getCollection('projects'))
  .filter((project) => project.data.locale === locale && project.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout locale={locale}>
  <section class="hero shell">
    <AudioField />
    <div class="hero__content">
      <p class="eyebrow"><span></span>{t.hero.eyebrow}</p>
      <h1>{t.hero.lead}</h1>
      <p class="hero__bio">{t.hero.bio}</p>
      <div class="hero__actions">
        <a class="button button--primary" href={localePath(locale, '/projects/')}>{t.hero.projects}<span>↗</span></a>
        <a class="button" href={localePath(locale, '/publications/')}>{t.hero.publications}<span>→</span></a>
      </div>
    </div>
    <div class="hero__coordinates" aria-hidden="true">
      <span>35.6812° N</span><span>139.7671° E</span><span>KEIO / TOKYO</span>
    </div>
    <div class="hero__scroll"><span></span>{t.hero.scroll}</div>
  </section>

  <section class="section shell" id="research">
    <div class="section-heading">
      <p class="eyebrow"><span></span>{t.sections.researchKicker}</p>
      <h2>{t.sections.researchTitle}</h2>
      <p>{t.sections.researchIntro}</p>
    </div>
    <div class="research-grid">
      {t.researchAreas.map((area) => (
        <article class="research-card">
          <span>{area.index}</span>
          <h3>{area.title}</h3>
          <p>{area.text}</p>
          <div class="research-card__trace"></div>
        </article>
      ))}
    </div>
  </section>

  <section class="section section--projects shell">
    <div class="section-heading section-heading--split">
      <div><p class="eyebrow"><span></span>{t.sections.projectsKicker}</p><h2>{t.sections.projectsTitle}</h2></div>
      <a class="text-link" href={localePath(locale, '/projects/')}>{t.sections.allProjects}<span>↗</span></a>
    </div>
    <div class="project-list">
      {projects.map((project, index) => <ProjectCard project={project} locale={locale} index={index} />)}
    </div>
  </section>

  <section class="section section--publications shell">
    <div class="section-heading section-heading--split">
      <div><p class="eyebrow"><span></span>{t.sections.publicationsKicker}</p><h2>{t.sections.publicationsTitle}</h2></div>
      <a class="text-link" href={localePath(locale, '/publications/')}>{t.sections.allPublications}<span>↗</span></a>
    </div>
    <PublicationList locale={locale} featuredOnly />
  </section>
</BaseLayout>
