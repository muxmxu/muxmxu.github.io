<div class="audio-field" aria-hidden="true">
  <canvas data-audio-field></canvas>
  <div class="audio-field__orb"></div>
</div>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>('[data-audio-field]');
  if (canvas) {
    const context = canvas.getContext('2d');
    const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
    let width = 0;
    let height = 0;
    let frame = 0;
    let pointerX = 0.65;
    let pointerY = 0.38;

    const resize = () => {
      const ratio = Math.min(devicePixelRatio, 2);
      width = canvas.clientWidth;
      height = canvas.clientHeight;
      canvas.width = width * ratio;
      canvas.height = height * ratio;
      context?.setTransform(ratio, 0, 0, ratio, 0, 0);
    };

    const draw = (time = 0) => {
      if (!context) return;
      context.clearRect(0, 0, width, height);
      const lines = 11;
      for (let line = 0; line < lines; line += 1) {
        const progress = line / (lines - 1);
        const yBase = height * (0.18 + progress * 0.64);
        const amplitude = 8 + (1 - Math.abs(progress - pointerY)) * 30;
        const gradient = context.createLinearGradient(0, 0, width, 0);
        gradient.addColorStop(0, 'rgba(190, 255, 111, 0)');
        gradient.addColorStop(0.34, `rgba(190, 255, 111, ${0.12 + progress * 0.08})`);
        gradient.addColorStop(0.72, `rgba(155, 135, 255, ${0.22 - progress * 0.08})`);
        gradient.addColorStop(1, 'rgba(155, 135, 255, 0)');
        context.beginPath();
        for (let x = 0; x <= width; x += 5) {
          const envelope = Math.sin((x / width) * Math.PI);
          const phase = x * 0.016 + progress * 6 + time * 0.00035;
          const resonance = Math.sin(phase) + 0.35 * Math.sin(phase * 2.3 + pointerX * 5);
          const y = yBase + resonance * amplitude * envelope * (0.35 + pointerX * 0.65);
          if (x === 0) context.moveTo(x, y);
          else context.lineTo(x, y);
        }
        context.strokeStyle = gradient;
        context.lineWidth = line === 5 ? 1.4 : 0.75;
        context.stroke();
      }
      if (!reducedMotion) frame = requestAnimationFrame(draw);
    };

    window.addEventListener('resize', resize);
    window.addEventListener('pointermove', (event) => {
      pointerX = event.clientX / innerWidth;
      pointerY = event.clientY / innerHeight;
    }, { passive: true });
    resize();
    draw();
    document.addEventListener('astro:before-swap', () => cancelAnimationFrame(frame), { once: true });
  }
</script>
